# Aegis - Environment Configuration
# Copy to .env and customize for your environment

# Application
APP_NAME="Aegis"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=true
LOG_LEVEL="DEBUG"
LOG_FORMAT="json"

# API Server
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_platform"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Vector Database
VECTOR_DB_PROVIDER="pgvector"
PGVECTOR_DIMENSION=1536
CHROMA_HOST="localhost"
CHROMA_PORT=8000

# LLM Provider (OpenRouter)
LLM_PROVIDER="openrouter"
OPENROUTER_API_KEY="${OPENROUTER_API_KEY}"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# Alternative LLM Providers (uncomment to use)
# OPENAI_API_KEY="${OPENAI_API_KEY}"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4-turbo-preview"
# ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}"
# ANTHROPIC_MODEL="claude-3-opus-20240229"

# Authentication
JWT_SECRET_KEY="${JWT_SECRET_KEY}"
JWT_ALGORITHM="RS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER="agentic-platform"
JWT_AUDIENCE="agentic-api"

# ServiceNow Integration
SERVICENOW_INSTANCE="${SERVICENOW_INSTANCE}"
SERVICENOW_USERNAME="${SERVICENOW_USERNAME}"
SERVICENOW_PASSWORD="${SERVICENOW_PASSWORD}"
SERVICENOW_CLIENT_ID="${SERVICENOW_CLIENT_ID}"
SERVICENOW_CLIENT_SECRET="${SERVICENOW_CLIENT_SECRET}"
SERVICENOW_API_VERSION="v2"

# Monitoring & Observability
PROMETHEUS_URL="http://localhost:9090"
GRAFANA_URL="http://localhost:3000"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="agentic-platform"
OTEL_RESOURCE_ATTRIBUTES="service.name=agentic-platform,deployment.environment=development"

# Alerting
ALERTMANAGER_URL="http://localhost:9093"
PAGERDUTY_INTEGRATION_KEY="${PAGERDUTY_INTEGRATION_KEY}"
SLACK_WEBHOOK_URL="${SLACK_WEBHOOK_URL}"
SENDGRID_API_KEY="${SENDGRID_API_KEY}"

# Kubernetes
KUBECONFIG="${KUBECONFIG}"
K8S_NAMESPACE="agentic-platform"
K8S_CLUSTER_NAME="agentic-cluster"

# Cloud Providers (configure as needed)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
GCP_PROJECT_ID="${GCP_PROJECT_ID}"
GCP_CREDENTIALS="${GCP_CREDENTIALS}"
AZURE_SUBSCRIPTION_ID="${AZURE_SUBSCRIPTION_ID}"
AZURE_TENANT_ID="${AZURE_TENANT_ID}"
AZURE_CLIENT_ID="${AZURE_CLIENT_ID}"
AZURE_CLIENT_SECRET="${AZURE_CLIENT_SECRET}"

# Security
ENCRYPTION_KEY="${ENCRYPTION_KEY}"
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Agent Orchestration
ORCHESTRATOR_MAX_CONCURRENT_AGENTS=10
ORCHESTRATOR_TIMEOUT_SECONDS=300
PLANNER_MAX_STEPS=20
EXECUTOR_MAX_RETRIES=3
OBSERVER_POLL_INTERVAL_SECONDS=10
VALIDATOR_THRESHOLD=0.85

# Knowledge Base
KB_EMBEDDING_MODEL="text-embedding-3-small"
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_TOP_K=5
KB_SIMILARITY_THRESHOLD=0.75

# Self-Healing
SELF_HEALING_ENABLED=true
SELF_HEALING_MAX_ACTIONS_PER_INCIDENT=5
SELF_HEALING_APPROVAL_REQUIRED=true
SELF_HEALING_DRY_RUN=true

# Feature Flags
FEATURE_PREDICTIVE_FAILURE=true
FEATURE_INTELLIGENT_ROUTING=true
FEATURE_ROOT_CAUSE_ANALYSIS=true
FEATURE_AUTO_REMEDIATION=true
FEATURE_CHAOS_ENGINEERING=false